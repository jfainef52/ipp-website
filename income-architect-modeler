<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>IncomeArchitect™ Modeler — Integrated Planning Partners</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Barlow+Condensed:wght@400;500;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0B1220; --navy2:#0E1628; --navy3:#111D33; --navy4:#15223C;
  --gold:#C8A96E; --gold2:#D4B87A; --gold-dim:rgba(200,169,110,.18);
  --off-white:#EDE8DE; --warm:#B8B0A0; --gray:#6B7280;
  --border:rgba(200,169,110,.15); --border2:rgba(255,255,255,.07);
  --green:#4A9B7A; --red:#C47A7A; --blue:#5B8FA8; --amber:#C8A030;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--navy);color:var(--off-white);font-family:'Barlow',sans-serif;font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased;}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(11,18,32,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:64px;}
.nav-logo{display:flex;align-items:center;gap:14px;text-decoration:none;}
.nav-brand-text{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--warm);line-height:1.4;}
.nav-links{display:flex;align-items:center;gap:24px;}
.nav-links a{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--warm);text-decoration:none;transition:color .2s;}
.nav-links a:hover,.nav-links a.active{color:var(--gold);}
.nav-ctas{display:flex;align-items:center;gap:10px;}
.btn-nav-outline{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--off-white);border:1px solid rgba(255,255,255,.2);padding:8px 16px;text-decoration:none;transition:all .2s;}
.btn-nav-outline:hover{border-color:var(--gold);color:var(--gold);}
.btn-nav-gold{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--navy);background:var(--gold);padding:9px 18px;text-decoration:none;transition:background .2s;}
.btn-nav-gold:hover{background:var(--gold2);}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;gap:0;align-items:stretch;padding-top:64px;}
.hero-left{padding:80px 60px 80px 80px;display:flex;flex-direction:column;justify-content:center;background:linear-gradient(145deg,#0B1220 0%,#0D1828 100%);}
.hero-right{position:relative;overflow:hidden;background:#080E1A;}
.hero-right img{width:100%;height:100%;object-fit:cover;object-position:top left;display:block;}
.hero-right::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(11,18,32,.6) 0%,transparent 30%);pointer-events:none;}
.eyebrow{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;display:flex;align-items:center;gap:14px;}
.eyebrow::before{content:'';display:block;width:32px;height:1px;background:var(--gold);}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(38px,4.5vw,60px);font-weight:300;line-height:1.08;margin-bottom:22px;}
.hero h1 em{font-style:italic;color:var(--gold);}
.hero-lead{font-size:16px;color:var(--warm);line-height:1.8;margin-bottom:36px;max-width:500px;}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;}
.btn-primary{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--navy);background:var(--gold);padding:14px 28px;text-decoration:none;display:inline-block;transition:background .2s;}
.btn-primary:hover{background:var(--gold2);}
.btn-secondary{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--off-white);border:1px solid rgba(255,255,255,.2);padding:14px 28px;text-decoration:none;display:inline-block;transition:all .2s;}
.btn-secondary:hover{border-color:var(--gold);color:var(--gold);}

/* STATS */
.stats{background:var(--navy3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:52px 80px;}
.stats-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:space-around;gap:32px;flex-wrap:wrap;}
.stat-val{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:300;color:var(--gold);line-height:1;margin-bottom:6px;}
.stat-lbl{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--warm);text-align:center;}

/* SECTIONS */
section{padding:88px 80px;}
.section-inner{max-width:1200px;margin:0 auto;}
.s-eyebrow{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:flex;align-items:center;gap:14px;}
.s-eyebrow::before{content:'';display:block;width:32px;height:1px;background:var(--gold);}
.s-h{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.2vw,44px);font-weight:300;line-height:1.15;margin-bottom:16px;}
.s-h em{font-style:italic;color:var(--gold);}
.s-sub{font-size:15px;color:var(--warm);line-height:1.8;max-width:660px;}

/* CAPABILITIES */
.cap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:56px;}
.cap-card{background:var(--navy2);padding:32px 26px;transition:background .2s;}
.cap-card:hover{background:var(--navy3);}
.cap-num{font-family:'Cormorant Garamond',serif;font-size:42px;font-weight:300;color:var(--gold-dim);line-height:1;margin-bottom:14px;}
.cap-title{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.cap-desc{font-size:14px;color:var(--warm);line-height:1.8;}

/* SCREENSHOT FEATURES */
.feat{padding:72px 64px;}
.feat.dark{background:var(--navy2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.feat-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:5fr 7fr;gap:56px;align-items:center;}
.feat-inner.rev{direction:rtl;grid-template-columns:7fr 5fr;}
.feat-inner.rev>*{direction:ltr;}
.feat-lbl{font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:flex;align-items:center;gap:12px;}.feat-lbl::before{content:'';display:block;width:28px;height:1px;background:var(--gold);flex-shrink:0;}
.feat-h{font-family:'Cormorant Garamond',serif;font-size:clamp(24px,2.8vw,36px);font-weight:300;line-height:1.15;margin-bottom:16px;}
.feat-h em{font-style:italic;color:var(--gold);}
.feat-body{font-size:14px;color:var(--warm);line-height:1.9;margin-bottom:18px;}
.feat-pts{list-style:none;display:flex;flex-direction:column;gap:8px;}
.feat-pts li{display:flex;gap:10px;font-size:14px;color:var(--warm);}
.feat-pts li::before{content:'—';color:var(--gold);flex-shrink:0;}
.screen-wrap{position:relative;}
.screen-frame{background:#080E1A;border:1px solid var(--border2);border-radius:6px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.55);}
.screen-bar{background:#0D1827;border-bottom:1px solid rgba(255,255,255,.06);padding:9px 14px;display:flex;align-items:center;gap:5px;}
.dot{width:7px;height:7px;border-radius:50%;}
.screen-url{flex:1;background:rgba(255,255,255,.04);border-radius:3px;padding:2px 8px;font-family:'Barlow Condensed',sans-serif;font-size:9px;color:var(--gray);margin-left:6px;letter-spacing:.02em;}
.screen-frame img{width:100%;display:block;}
.badge-float{position:absolute;top:-13px;right:-13px;background:var(--navy);border:1px solid var(--gold);padding:7px 12px;font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);}
.conf-badge{position:absolute;bottom:16px;right:16px;background:rgba(11,18,32,.9);border:1px solid var(--gold);border-radius:50%;width:56px;height:56px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;}
.conf-pct{font-size:16px;font-weight:700;color:var(--gold);line-height:1;}
.conf-lbl{font-size:7px;letter-spacing:.08em;text-transform:uppercase;color:var(--warm);}

/* AUDIENCE */
.aud-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:52px;}
.aud-card{background:var(--navy2);border:1px solid var(--border2);border-top:3px solid var(--gold);padding:36px 30px;}
.aud-card.blue{border-top-color:var(--blue);}
.aud-icon{font-size:26px;margin-bottom:16px;}
.aud-h{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:600;margin-bottom:10px;}
.aud-body{font-size:14px;color:var(--warm);line-height:1.8;margin-bottom:20px;}
.aud-pts{list-style:none;display:flex;flex-direction:column;gap:7px;}
.aud-pts li{display:flex;gap:9px;font-size:13px;color:var(--warm);}
.aud-pts li::before{content:'✓';color:var(--gold);font-weight:700;flex-shrink:0;}

/* CALLOUT */
.callout{background:var(--navy3);border:1px solid var(--border);border-left:3px solid var(--gold);padding:36px 40px;margin-top:52px;}
.callout-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:28px;}
.cl-lbl{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.cl-val{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;color:var(--off-white);margin-bottom:5px;}
.cl-desc{font-size:13px;color:var(--warm);line-height:1.6;}

/* QUOTE */
.quote-wrap{padding:72px 80px;text-align:center;background:var(--navy2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.quote-inner{max-width:760px;margin:0 auto;}
blockquote{font-family:'Cormorant Garamond',serif;font-size:clamp(20px,2.5vw,30px);font-style:italic;font-weight:300;color:var(--off-white);line-height:1.5;margin-bottom:20px;}
.q-attr{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);}

/* DUAL CTA */
.cta-wrap{padding:88px 80px;background:var(--navy2);border-top:1px solid var(--border);}
.cta-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:32px;}
.cta-card{background:var(--navy3);border:1px solid var(--border2);border-top:3px solid var(--gold);padding:44px 36px;}
.cta-card.blue{border-top-color:var(--blue);}
.cta-lbl{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;}
.cta-card.blue .cta-lbl{color:var(--blue);}
.cta-h{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;margin-bottom:14px;}
.cta-body{font-size:14px;color:var(--warm);line-height:1.8;margin-bottom:26px;}
.btn-blue{background:var(--blue);color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:13px 26px;text-decoration:none;display:inline-block;transition:opacity .2s;}
.btn-blue:hover{opacity:.85;}

/* FOOTER */
footer{background:var(--navy);border-top:1px solid var(--border);padding:44px 80px;}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:28px;}
.footer-brand{display:flex;align-items:center;gap:14px;margin-bottom:8px;}
.footer-tagline{font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);}
.footer-links{display:flex;gap:20px;flex-wrap:wrap;}
.footer-links a{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gray);text-decoration:none;}
.footer-links a:hover{color:var(--gold);}
.footer-legal{font-size:11px;color:var(--gray);line-height:1.6;width:100%;margin-top:18px;border-top:1px solid var(--border2);padding-top:18px;}

@media(max-width:960px){
  .hero{grid-template-columns:1fr;min-height:auto;}
  .hero-right{height:280px;}
  .feat-inner,.feat-inner.rev,.aud-grid,.cta-inner,.cap-grid{grid-template-columns:1fr;direction:ltr;}
  section,.feat,.stats,.cta-wrap,footer,.quote-wrap{padding:56px 24px;}
  .hero-left{padding:80px 24px 40px;}
  .callout-grid{grid-template-columns:1fr;}
}
</style>
</head>
